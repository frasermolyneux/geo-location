@using MX.GeoLocation.Web.Extensions
@using MX.GeoLocation.Web.Models
@using MX.GeoLocation.Abstractions.Models.V1_1
@inject IConfiguration Configuration
@model IntelligenceLookupViewModel

@{
    ViewData["Title"] = "Intelligence Lookup";
}

<!-- Page Header -->
<div class="hero-section fade-in">
    <h1 class="display-4 mb-3">
        <svg class="icon icon-xl me-2" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z" />
        </svg>
        Intelligence Lookup
    </h1>
    <p class="lead">Enter any IP address or domain to discover its geographic location, risk assessment, and anonymizer data</p>
</div>

<!-- Search Form -->
<div class="form-section fade-in">
    <h2>
        <svg class="icon me-2" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z" />
        </svg>
        Search Intelligence
    </h2>

    <form asp-controller="Home" asp-action="IntelligenceLookup" method="post" autocomplete="off">
        <div class="input-group">
            <svg class="input-icon icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <circle cx="11" cy="11" r="8" />
                <path d="m21 21-4.35-4.35" />
            </svg>
            <input asp-for="@Model.AddressData" class="form-control"
                placeholder="Enter IP address or domain (e.g., 8.8.8.8 or google.com)"
                aria-label="IP address or domain">
            <button class="btn btn-primary" type="submit" id="search">
                <svg class="icon icon-sm me-1" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <circle cx="11" cy="11" r="8" />
                    <path d="m21 21-4.35-4.35" />
                </svg>
                Lookup
            </button>
        </div>

        @if (!ViewData.ModelState.IsValid)
        {
            <div class="mt-3">
                <div class="alert alert-danger" role="alert">
                    <div class="d-flex align-items-start">
                        <svg class="icon icon-sm me-2 mt-1 flex-shrink-0" viewBox="0 0 24 24" fill="none"
                            stroke="currentColor" stroke-width="2">
                            <circle cx="12" cy="12" r="10" />
                            <line x1="15" y1="9" x2="9" y2="15" />
                            <line x1="9" y1="9" x2="15" y2="15" />
                        </svg>
                        <div class="flex-grow-1">
                            <h6 class="alert-heading mb-2">Please correct the following errors:</h6>
                            <div class="small">
                                @Html.ValidationSummary(false)
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        }
    </form>

    <div class="mt-3">
        <p class="text-muted mb-0">
            <svg class="icon icon-sm me-1" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <circle cx="12" cy="12" r="10" />
                <line x1="12" y1="16" x2="12" y2="12" />
                <line x1="12" y1="8" x2="12.01" y2="8" />
            </svg>
            Enter an IP address (IPv4 or IPv6) or domain name to retrieve full intelligence data including risk assessment and anonymizer information.
        </p>
    </div>
</div>

@if (Model.Intelligence is not null)
{
    var intel = Model.Intelligence;

    <!-- Summary Header -->
    <div class="result-card fade-in">
        <div class="result-header">
            @intel.FlagImage()
            <div>
                <h2 class="mb-1">@Model.AddressData</h2>
                <p class="text-muted mb-0">Located in @intel.LocationSummary()</p>
            </div>
            <div class="ms-auto d-flex align-items-center gap-2">
                <span class="badge @intel.ProxyCheck.RiskBadgeClass() fs-6">
                    @(intel.ProxyCheck?.RiskScore.ToString() ?? "N/A") - @intel.ProxyCheck.RiskLabel()
                </span>
                <div class="status-indicator status-success">
                    <svg class="icon icon-sm" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <polyline points="20,6 9,17 4,12" />
                    </svg>
                    Found
                </div>
            </div>
        </div>

        <div class="row">
            <!-- Map Section -->
            <div class="col-lg-8 mb-4">
                <div class="card">
                    <div class="card-header">
                        <h3 class="mb-0">
                            <svg class="icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                <polygon points="1 6 1 22 8 18 16 22 23 18 23 2 16 6 8 2 1 6" />
                                <line x1="8" y1="2" x2="8" y2="18" />
                                <line x1="16" y1="6" x2="16" y2="22" />
                            </svg>
                            Geographic Location
                        </h3>
                    </div>
                    <div class="card-body p-0">
                        <div id="map" style="height: 450px; width: 100%;"></div>
                    </div>
                </div>
            </div>

            <!-- Risk Assessment Card -->
            <div class="col-lg-4 mb-4">
                <div class="card h-100">
                    <div class="card-header">
                        <h3 class="mb-0">
                            <svg class="icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z" />
                            </svg>
                            Risk Assessment
                        </h3>
                    </div>
                    <div class="card-body">
                        <div class="text-center mb-3">
                            <span class="badge @intel.ProxyCheck.RiskBadgeClass() fs-4 px-4 py-2">
                                @(intel.ProxyCheck?.RiskScore.ToString() ?? "N/A")
                            </span>
                            <p class="text-muted mt-2 mb-0">@intel.ProxyCheck.RiskLabel()</p>
                        </div>
                        <div class="d-flex flex-wrap gap-2 justify-content-center mb-3">
                            @if (intel.ProxyCheck?.IsProxy == true)
                            {
                                <span class="badge text-bg-danger">Proxy</span>
                            }
                            @if (intel.ProxyCheck?.IsVpn == true)
                            {
                                <span class="badge text-bg-warning">VPN</span>
                            }
                            @if (!string.IsNullOrWhiteSpace(intel.ProxyCheck?.ProxyType))
                            {
                                <span class="badge text-bg-secondary">@intel.ProxyCheck.ProxyType</span>
                            }
                        </div>
                        <hr />
                        <div class="table-responsive">
                            <table class="table table-borderless table-sm mb-0">
                                <tbody>
                                    <tr>
                                        <td class="text-muted">MaxMind Status</td>
                                        <td><span class="badge @intel.MaxMindStatus.SourceStatusBadgeClass()">@intel.MaxMindStatus</span></td>
                                    </tr>
                                    <tr>
                                        <td class="text-muted">ProxyCheck Status</td>
                                        <td><span class="badge @intel.ProxyCheckStatus.SourceStatusBadgeClass()">@intel.ProxyCheckStatus</span></td>
                                    </tr>
                                    @if (intel.IsPartial)
                                    {
                                        <tr>
                                            <td colspan="2">
                                                <div class="alert alert-warning py-1 px-2 mb-0 small">
                                                    <svg class="icon icon-sm me-1" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                                        <path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z" />
                                                        <line x1="12" y1="9" x2="12" y2="13" />
                                                        <line x1="12" y1="17" x2="12.01" y2="17" />
                                                    </svg>
                                                    Partial result — one or more data sources failed
                                                </div>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Anonymizer Card -->
    @if (intel.Anonymizer != null)
    {
        <div class="card mb-4">
            <div class="card-header">
                <h3 class="mb-0 d-flex align-items-center gap-2">
                    <svg class="icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2" />
                        <circle cx="12" cy="7" r="4" />
                    </svg>
                    Anonymizer Data
                </h3>
            </div>
            <div class="card-body">
                <div class="table-responsive">
                    <table class="table table-borderless">
                        <tbody>
                            <tr>
                                <td class="text-muted">Is Anonymous</td>
                                <td class="fw-medium">
                                    @if (intel.Anonymizer.IsAnonymous)
                                    {
                                        <span class="badge text-bg-danger">Yes</span>
                                    }
                                    else
                                    {
                                        <span class="badge text-bg-success">No</span>
                                    }
                                </td>
                            </tr>
                            <tr>
                                <td class="text-muted">Is Anonymous VPN</td>
                                <td class="fw-medium">
                                    @if (intel.Anonymizer.IsAnonymousVpn)
                                    {
                                        <span class="badge text-bg-danger">Yes</span>
                                    }
                                    else
                                    {
                                        <span class="badge text-bg-success">No</span>
                                    }
                                </td>
                            </tr>
                            <tr>
                                <td class="text-muted">Is Hosting Provider</td>
                                <td class="fw-medium">
                                    @if (intel.Anonymizer.IsHostingProvider)
                                    {
                                        <span class="badge text-bg-warning">Yes</span>
                                    }
                                    else
                                    {
                                        <span class="badge text-bg-success">No</span>
                                    }
                                </td>
                            </tr>
                            <tr>
                                <td class="text-muted">Is Public Proxy</td>
                                <td class="fw-medium">
                                    @if (intel.Anonymizer.IsPublicProxy)
                                    {
                                        <span class="badge text-bg-danger">Yes</span>
                                    }
                                    else
                                    {
                                        <span class="badge text-bg-success">No</span>
                                    }
                                </td>
                            </tr>
                            <tr>
                                <td class="text-muted">Is Residential Proxy</td>
                                <td class="fw-medium">
                                    @if (intel.Anonymizer.IsResidentialProxy)
                                    {
                                        <span class="badge text-bg-warning">Yes</span>
                                    }
                                    else
                                    {
                                        <span class="badge text-bg-success">No</span>
                                    }
                                </td>
                            </tr>
                            <tr>
                                <td class="text-muted">Is Tor Exit Node</td>
                                <td class="fw-medium">
                                    @if (intel.Anonymizer.IsTorExitNode)
                                    {
                                        <span class="badge text-bg-danger">Yes</span>
                                    }
                                    else
                                    {
                                        <span class="badge text-bg-success">No</span>
                                    }
                                </td>
                            </tr>
                            @if (intel.Anonymizer.Confidence.HasValue)
                            {
                                <tr>
                                    <td class="text-muted">Confidence</td>
                                    <td class="fw-medium">@intel.Anonymizer.Confidence%</td>
                                </tr>
                            }
                            @if (!string.IsNullOrWhiteSpace(intel.Anonymizer.ProviderName))
                            {
                                <tr>
                                    <td class="text-muted">Provider Name</td>
                                    <td class="fw-medium">@intel.Anonymizer.ProviderName</td>
                                </tr>
                            }
                            @if (!string.IsNullOrWhiteSpace(intel.Anonymizer.NetworkLastSeen))
                            {
                                <tr>
                                    <td class="text-muted">Network Last Seen</td>
                                    <td class="fw-medium">@intel.Anonymizer.NetworkLastSeen</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    }

    <!-- Location Card -->
    <div class="card mb-4">
        <div class="card-header">
            <h3 class="mb-0 d-flex align-items-center gap-2">
                <svg class="icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z" />
                    <circle cx="12" cy="10" r="3" />
                </svg>
                Location Details
            </h3>
        </div>
        <div class="card-body">
            <div class="table-responsive">
                <table class="table table-borderless">
                    <tbody>
                        <tr>
                            <td class="text-muted">Country</td>
                            <td class="fw-medium">
                                <div class="d-flex align-items-center gap-2">
                                    @intel.FlagImage()
                                    @intel.CountryName (@intel.CountryCode)
                                </div>
                            </td>
                        </tr>
                        @if (!string.IsNullOrWhiteSpace(intel.CityName))
                        {
                            <tr>
                                <td class="text-muted">City</td>
                                <td class="fw-medium">@intel.CityName</td>
                            </tr>
                        }
                        @if (!string.IsNullOrWhiteSpace(intel.ContinentName))
                        {
                            <tr>
                                <td class="text-muted">Continent</td>
                                <td class="fw-medium">@intel.ContinentName (@intel.ContinentCode)</td>
                            </tr>
                        }
                        <tr>
                            <td class="text-muted">Coordinates</td>
                            <td class="fw-medium">@intel.Latitude, @intel.Longitude</td>
                        </tr>
                        <tr>
                            <td class="text-muted">Accuracy Radius</td>
                            <td class="fw-medium">@intel.AccuracyRadius KM</td>
                        </tr>
                        @if (!string.IsNullOrWhiteSpace(intel.PostalCode))
                        {
                            <tr>
                                <td class="text-muted">Postal Code</td>
                                <td class="fw-medium">@intel.PostalCode</td>
                            </tr>
                        }
                        <tr>
                            <td class="text-muted">Timezone</td>
                            <td class="fw-medium">@intel.Timezone</td>
                        </tr>
                        <tr>
                            <td class="text-muted">European Union</td>
                            <td class="fw-medium">
                                @if (intel.IsEuropeanUnion)
                                {
                                    <span class="badge text-bg-info">Yes</span>
                                }
                                else
                                {
                                    <span class="badge text-bg-secondary">No</span>
                                }
                            </td>
                        </tr>
                        @if (intel.Subdivisions.Count > 0)
                        {
                            <tr>
                                <td class="text-muted">Subdivisions</td>
                                <td class="fw-medium">
                                    <div class="d-flex flex-wrap gap-1">
                                        @foreach (var subdivision in intel.Subdivisions)
                                        {
                                            <span class="badge text-bg-secondary">@subdivision</span>
                                        }
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <!-- Network Traits Card -->
    @if (intel.NetworkTraits != null)
    {
        <div class="card mb-4">
            <div class="card-header">
                <h3 class="mb-0 d-flex align-items-center gap-2">
                    <svg class="icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <rect x="3" y="3" width="18" height="18" rx="2" ry="2" />
                        <path d="M9 9h6v6H9z" />
                    </svg>
                    Network Traits
                </h3>
            </div>
            <div class="card-body">
                <div class="table-responsive">
                    <table class="table table-borderless">
                        <tbody>
                            @if (intel.NetworkTraits.AutonomousSystemNumber.HasValue)
                            {
                                <tr>
                                    <td class="text-muted">Autonomous System Number</td>
                                    <td class="fw-medium">@intel.NetworkTraits.AutonomousSystemNumber</td>
                                </tr>
                            }
                            @if (!string.IsNullOrWhiteSpace(intel.NetworkTraits.AutonomousSystemOrganization))
                            {
                                <tr>
                                    <td class="text-muted">AS Organization</td>
                                    <td class="fw-medium">@intel.NetworkTraits.AutonomousSystemOrganization</td>
                                </tr>
                            }
                            @if (!string.IsNullOrWhiteSpace(intel.NetworkTraits.Isp))
                            {
                                <tr>
                                    <td class="text-muted">ISP</td>
                                    <td class="fw-medium">@intel.NetworkTraits.Isp</td>
                                </tr>
                            }
                            @if (!string.IsNullOrWhiteSpace(intel.NetworkTraits.Organization))
                            {
                                <tr>
                                    <td class="text-muted">Organization</td>
                                    <td class="fw-medium">@intel.NetworkTraits.Organization</td>
                                </tr>
                            }
                            @if (!string.IsNullOrWhiteSpace(intel.NetworkTraits.ConnectionType))
                            {
                                <tr>
                                    <td class="text-muted">Connection Type</td>
                                    <td class="fw-medium">@intel.NetworkTraits.ConnectionType</td>
                                </tr>
                            }
                            @if (!string.IsNullOrWhiteSpace(intel.NetworkTraits.Domain))
                            {
                                <tr>
                                    <td class="text-muted">Domain</td>
                                    <td class="fw-medium">@intel.NetworkTraits.Domain</td>
                                </tr>
                            }
                            @if (!string.IsNullOrWhiteSpace(intel.NetworkTraits.UserType))
                            {
                                <tr>
                                    <td class="text-muted">User Type</td>
                                    <td class="fw-medium">@intel.NetworkTraits.UserType</td>
                                </tr>
                            }
                            @if (!string.IsNullOrWhiteSpace(intel.NetworkTraits.Network))
                            {
                                <tr>
                                    <td class="text-muted">Network</td>
                                    <td class="fw-medium">@intel.NetworkTraits.Network</td>
                                </tr>
                            }
                            @if (intel.NetworkTraits.IsAnycast)
                            {
                                <tr>
                                    <td class="text-muted">Anycast</td>
                                    <td class="fw-medium">Yes</td>
                                </tr>
                            }
                            @if (intel.NetworkTraits.StaticIPScore.HasValue)
                            {
                                <tr>
                                    <td class="text-muted">Static IP Score</td>
                                    <td class="fw-medium">@intel.NetworkTraits.StaticIPScore</td>
                                </tr>
                            }
                            @if (intel.NetworkTraits.UserCount.HasValue)
                            {
                                <tr>
                                    <td class="text-muted">User Count</td>
                                    <td class="fw-medium">@intel.NetworkTraits.UserCount</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    }

    <!-- Source Status Footer -->
    <div class="card mb-4">
        <div class="card-body">
            <div class="d-flex flex-wrap align-items-center gap-3">
                <span class="text-muted">Data Sources:</span>
                <span class="badge @intel.MaxMindStatus.SourceStatusBadgeClass()">
                    MaxMind: @intel.MaxMindStatus
                </span>
                <span class="badge @intel.ProxyCheckStatus.SourceStatusBadgeClass()">
                    ProxyCheck: @intel.ProxyCheckStatus
                </span>
                @if (intel.IsPartial)
                {
                    <span class="badge text-bg-warning">
                        <svg class="icon icon-sm me-1" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z" />
                            <line x1="12" y1="9" x2="12" y2="13" />
                            <line x1="12" y1="17" x2="12.01" y2="17" />
                        </svg>
                        Partial Result
                    </span>
                }
            </div>
        </div>
    </div>

    @section Scripts {
        <script>
            function initMap() {
                var myLatLng = {
                    lat: @intel.Latitude,
                    lng: @intel.Longitude
                };

                var map = new google.maps.Map(document.getElementById('map'), {
                    zoom: 8,
                    center: myLatLng,
                    styles: [
                        {
                            "featureType": "all",
                            "elementType": "geometry.fill",
                            "stylers": [
                                {
                                    "weight": "2.00"
                                }
                            ]
                        },
                        {
                            "featureType": "all",
                            "elementType": "geometry.stroke",
                            "stylers": [
                                {
                                    "color": "#9c9c9c"
                                }
                            ]
                        },
                        {
                            "featureType": "all",
                            "elementType": "labels.text",
                            "stylers": [
                                {
                                    "visibility": "on"
                                }
                            ]
                        },
                        {
                            "featureType": "landscape",
                            "elementType": "all",
                            "stylers": [
                                {
                                    "color": "#f2f2f2"
                                }
                            ]
                        },
                        {
                            "featureType": "landscape",
                            "elementType": "geometry.fill",
                            "stylers": [
                                {
                                    "color": "#ffffff"
                                }
                            ]
                        },
                        {
                            "featureType": "landscape.man_made",
                            "elementType": "geometry.fill",
                            "stylers": [
                                {
                                    "color": "#ffffff"
                                }
                            ]
                        },
                        {
                            "featureType": "poi",
                            "elementType": "all",
                            "stylers": [
                                {
                                    "visibility": "off"
                                }
                            ]
                        },
                        {
                            "featureType": "road",
                            "elementType": "all",
                            "stylers": [
                                {
                                    "saturation": -100
                                },
                                {
                                    "lightness": 45
                                }
                            ]
                        },
                        {
                            "featureType": "road",
                            "elementType": "geometry.fill",
                            "stylers": [
                                {
                                    "color": "#eeeeee"
                                }
                            ]
                        },
                        {
                            "featureType": "road",
                            "elementType": "labels.text.fill",
                            "stylers": [
                                {
                                    "color": "#7b7b7b"
                                }
                            ]
                        },
                        {
                            "featureType": "road",
                            "elementType": "labels.text.stroke",
                            "stylers": [
                                {
                                    "color": "#ffffff"
                                }
                            ]
                        },
                        {
                            "featureType": "road.highway",
                            "elementType": "all",
                            "stylers": [
                                {
                                    "visibility": "simplified"
                                }
                            ]
                        },
                        {
                            "featureType": "road.arterial",
                            "elementType": "labels.icon",
                            "stylers": [
                                {
                                    "visibility": "off"
                                }
                            ]
                        },
                        {
                            "featureType": "transit",
                            "elementType": "all",
                            "stylers": [
                                {
                                    "visibility": "off"
                                }
                            ]
                        },
                        {
                            "featureType": "water",
                            "elementType": "all",
                            "stylers": [
                                {
                                    "color": "#46bcec"
                                },
                                {
                                    "visibility": "on"
                                }
                            ]
                        },
                        {
                            "featureType": "water",
                            "elementType": "geometry.fill",
                            "stylers": [
                                {
                                    "color": "#c8d7d4"
                                }
                            ]
                        },
                        {
                            "featureType": "water",
                            "elementType": "labels.text.fill",
                            "stylers": [
                                {
                                    "color": "#070707"
                                }
                            ]
                        },
                        {
                            "featureType": "water",
                            "elementType": "labels.text.stroke",
                            "stylers": [
                                {
                                    "color": "#ffffff"
                                }
                            ]
                        }
                    ]
                });

                var marker = new google.maps.Marker({
                    position: myLatLng,
                    map: map,
                    title: '@Model.AddressData Location',
                    icon: {
                        path: google.maps.SymbolPath.CIRCLE,
                        fillColor: '#3b82f6',
                        fillOpacity: 1,
                        strokeColor: '#ffffff',
                        strokeWeight: 3,
                        scale: 8
                    }
                });

                // Add info window
                var infoWindow = new google.maps.InfoWindow({
                    content: `
                        <div style="padding: 10px; font-family: 'Inter', sans-serif;">
                            <h6 style="margin: 0 0 8px 0; color: #1e293b;">@intel.LocationSummary()</h6>
                            <p style="margin: 0; color: #64748b; font-size: 14px;">@Model.AddressData</p>
                            <p style="margin: 4px 0 0 0; color: #64748b; font-size: 12px;">Accuracy: @intel.AccuracyRadius KM</p>
                        </div>
                    `
                });

                marker.addListener('click', function () {
                    infoWindow.open(map, marker);
                });

                // Auto-open info window
                setTimeout(function () {
                    infoWindow.open(map, marker);
                }, 1000);
            }

            // Initialize map when page loads
            document.addEventListener('DOMContentLoaded', function () {
                if (typeof google !== 'undefined') {
                    initMap();
                }
            });
        </script>

        @{ var mapsApiKey = Configuration["GoogleMaps:ApiKey"]; }
        @if (!string.IsNullOrWhiteSpace(mapsApiKey))
        {
            <script async defer
                src="https://maps.googleapis.com/maps/api/js?key=@mapsApiKey&signed_in=false&callback=initMap"></script>
        }
    }
}
